# Supabase — partagé avec VSM Ambassador Program (même projet, même auth)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# URL du Programme Ambassadeur (SSO redirect source)
VITE_AMBASSADOR_PROGRAM_URL=https://ambassadeur.vsmcollection.com

# Domaine Academy (production)
VITE_ACADEMY_URL=https://academy.vsmcollection.com

# Introspection / scripts uniquement — ne jamais exposer côté client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres

# Push Web — générer avec : node scripts/generate-vapid-keys.mjs
# Clé publique (client) :
VITE_VAPID_PUBLIC_KEY=
# Secrets Supabase Edge Function academy-web-push :
# VAPID_PUBLIC_KEY= (même valeur que ci-dessus)
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@vsmcollection.com

# WebRTC TURN (optionnel — openrelay utilisé par défaut en dev)
# VITE_TURN_URL=turn:your-turn-server:3478
# VITE_TURN_USERNAME=
# VITE_TURN_CREDENTIAL=
